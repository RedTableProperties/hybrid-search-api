CACHE_TTL=300
DEFAULT_EF=64
MAX_CANDIDATE_IDS=15000
POSTGRES_CIRCUIT_FAIL_MAX=5
POSTGRES_CIRCUIT_RESET_TIMEOUT=30
FAISS_CIRCUIT_FAIL_MAX=3
FAISS_CIRCUIT_RESET_TIMEOUT=15
SEARCH_RATE_LIMIT=300/minute
SEARCH_RATE_LIMIT_BURST=50
ENABLE_CACHE_WARMING=true
CACHE_WARMING_INTERVAL_HOURS=6
DATABASE_URL=postgresql://localhost/search
REDIS_URL=redis://localhost:6379/0
FAISS_INDEX_PATH=data/faiss.index